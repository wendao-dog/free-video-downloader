# 阿里百炼 API Key（必填）
BAILIAN_API_KEY=sk-your-bailian-api-key

# 可选：默认已配置为百炼兼容模式；按需修改
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# JWT 密钥（生产环境请使用强随机字符串）
# JWT_SECRET=my-jwt-secret-change-in-production
JWT_SECRET=my-local-jwt-secret-change-in-dev

# Stripe 支付配置
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id

# 前端 URL（用于 Stripe 支付回跳）
FRONTEND_URL=http://localhost:5173
